# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo

# VCS / CI
/.git/

# Node (not used, but safe to exclude)
node_modules/

# Logs
*.log

# App-specific temp/uploads (configure actual upload dir later)
/tmp/
/uploads/

# Credentials (we are using config.php; keep sensitive info out of commits)
.env
.env.*

# Claude Code local settings
.claude/

# Local image originals (pre-webp backup)
/public/images/_orig_backup/

# Uploaded resource files (user content)
/public/uploads/resources/

# Local-only demo credentials (never commit)
DEMO_LOGINS.local.md
